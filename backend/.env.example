# Environment Variables for Tamil Trucker Repair Backend

# Email Configuration (for password reset functionality)
# Using Gmail as an example - you can use any email service supported by Nodemailer

# Gmail SMTP Configuration
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password

# Alternative Email Services:
# Outlook: use your Outlook email and password
# SendGrid: EMAIL_USER=apikey, EMAIL_PASSWORD=your_sendgrid_api_key
# Mailgun: configure in the auth controller

# Frontend URL (used in password reset emails)
FRONTEND_URL=http://localhost:3000

# Database Configuration (when connected)
# MONGODB_URI=mongodb://localhost:27017/trucker-repair
# DB_NAME=trucker_repair

# JWT Configuration (when authentication is fully implemented)
# JWT_SECRET=your_super_secret_jwt_key_here
# JWT_EXPIRE=7d

# Port Configuration
# PORT=3001
# NODE_ENV=development
